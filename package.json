{
  "name": "@libreward/bridge",
  "version": "0.1.0-alpha.1",
  "description": "A privacy-preserving open-source bridge for distributing exact-value rewards through GNU Taler.",
  "license": "AGPL-3.0-or-later",
  "homepage": "https://github.com/robyroro/libreward-bridge#readme",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/robyroro/libreward-bridge.git"
  },
  "bugs": {
    "url": "https://github.com/robyroro/libreward-bridge/issues"
  },
  "type": "module",
  "engines": {
    "node": ">=22.0.0"
  },
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "dev": "tsx watch src/server.ts",
    "start": "node dist/src/server.js",
    "worker": "node dist/src/worker-main.js",
    "migrate": "tsx src/cli.ts migrate",
    "cli": "tsx src/cli.ts",
    "test": "vitest run",
    "test:unit": "vitest run tests/unit",
    "test:coverage": "vitest run tests/unit --coverage",
    "test:integration": "vitest run tests/integration",
    "test:integration:required": "node -e \"if (!process.env.TEST_DATABASE_URL) throw new Error('TEST_DATABASE_URL is required')\" && vitest run tests/integration",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "examples:typecheck": "tsc -p examples/reference-integrator/tsconfig.json --noEmit",
    "lint": "biome check .",
    "format": "biome format --write .",
    "format:check": "biome format .",
    "openapi:validate": "tsx scripts/validate-openapi.ts",
    "docs:links": "tsx scripts/check-markdown-links.ts",
    "check:artifacts": "tsx scripts/check-repository-artifacts.ts",
    "validate": "npm run format:check && npm run lint && npm run typecheck && npm run examples:typecheck && npm run test:unit && npm run openapi:validate && npm run docs:links && npm run check:artifacts && npm run build",
    "sandbox:evidence": "tsx scripts/run-funded-sandbox.ts",
    "license:check": "license-checker-rseidelsohn --production --onlyAllow=\"AGPL-3.0-or-later;MIT;ISC;BSD-2-Clause;BSD-3-Clause;Apache-2.0;MPL-2.0;BlueOak-1.0.0;CC-BY-4.0;Python-2.0\"",
    "sbom": "cyclonedx-npm --output-file sbom.cdx.json"
  },
  "dependencies": {
    "@fastify/helmet": "13.0.2",
    "@fastify/rate-limit": "10.3.0",
    "fastify": "5.10.0",
    "ipaddr.js": "2.2.0",
    "pg": "8.16.3",
    "prom-client": "15.1.3",
    "qrcode": "1.5.4",
    "undici": "7.28.0",
    "zod": "4.0.5"
  },
  "devDependencies": {
    "@biomejs/biome": "2.1.2",
    "@cyclonedx/cyclonedx-npm": "6.0.0",
    "@readme/openapi-parser": "5.0.1",
    "@types/node": "24.0.13",
    "@types/pg": "8.15.4",
    "@types/qrcode": "1.5.5",
    "@vitest/coverage-v8": "3.2.7",
    "license-checker-rseidelsohn": "4.4.2",
    "tsx": "4.20.3",
    "typescript": "5.8.3",
    "vitest": "3.2.7"
  }
}
