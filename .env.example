LIBREREWARD_ENV=development
LIBREREWARD_HOST=0.0.0.0
LIBREREWARD_PORT=8080
LIBREREWARD_PUBLIC_URL=http://localhost:8080
# Safe default. Set a bounded hop count or explicit comma-separated IP/CIDR allowlist only when
# every request reaches LibreReward through that trusted reverse proxy path.
LIBREREWARD_TRUST_PROXY=false
DATABASE_URL=postgres://libreward:libreward@localhost:5432/libreward
API_KEY_HASH_SECRET=development-only-change-me-32-bytes-minimum
OPERATOR_API_KEY_HASH_SECRET=development-only-operator-secret-change-me
CLAIM_TOKEN_HASH_SECRET=development-only-change-me-32-bytes-minimum
DATA_ENCRYPTION_KEY=AAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAA
PROVIDER=mock
TALER_WALLET_CLI=taler-wallet-cli
# Optional: path to the official wallet CLI .mjs when running a source build through Node.
TALER_WALLET_CLI_NODE_SCRIPT=
# Optional source-build compatibility override; packaged deployments normally leave this empty.
TALER_WALLET_CRYPTO_WORKER=
TALER_WALLET_COMMAND_TIMEOUT_MS=60000
TALER_WALLET_DB=/data/taler-wallet.sqlite3
# Stable production-shaped mode: socket created by `taler-wallet-cli advanced serve`.
TALER_WALLET_CONNECTION=
# Valueless sandbox compatibility only; rejected when LIBREREWARD_ENV=production.
TALER_WALLET_ALLOW_TESTING_API=false
TALER_EXCHANGE_BASE_URL=
TALER_ALLOW_HTTP=false
SUPPORTED_CURRENCIES=KUDOS,TESTKUDOS
CLAIM_TOKEN_TTL_SECONDS=604800
MAX_REWARD_VALUE=1000000
# Disable when tenant-supplied metadata is unnecessary. Metadata values are scalar and capped.
METADATA_ENABLED=true
DAILY_PAYOUT_LIMITS=
LIQUIDITY_MIN_BALANCES=
LIQUIDITY_MAX_AGE_SECONDS=300
LIQUIDITY_CHECK_INTERVAL_SECONDS=60
LIQUIDITY_FAIL_CLOSED=false
WEBHOOK_TIMEOUT_MS=5000
WEBHOOK_MAX_ATTEMPTS=8
WEBHOOK_ALLOW_PRIVATE=false
WORKER_POLL_MS=1000
RECONCILIATION_INTERVAL_SECONDS=60
RETENTION_INTERVAL_SECONDS=86400
CLAIM_TOKEN_RETENTION_DAYS=30
PROVIDER_SECRET_RETENTION_DAYS=30
WEBHOOK_DELIVERED_RETENTION_DAYS=90
WEBHOOK_FAILED_RETENTION_DAYS=180
REVOKED_KEY_RETENTION_DAYS=365
RATE_LIMIT_MAX=120
CLAIM_RATE_LIMIT_MAX=20
OPERATOR_RATE_LIMIT_MAX=60
METRICS_ENABLED=true
LOG_LEVEL=info
