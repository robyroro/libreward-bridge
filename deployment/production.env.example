LIBREREWARD_ENV=production
LIBREREWARD_PUBLIC_URL=https://bridge.example.invalid
DATABASE_URL=postgres://CHANGE_ME
API_KEY_HASH_SECRET=CHANGE_ME_IN_SECRET_MANAGER_MINIMUM_32_BYTES
OPERATOR_API_KEY_HASH_SECRET=CHANGE_ME_SEPARATELY_MINIMUM_32_BYTES
CLAIM_TOKEN_HASH_SECRET=CHANGE_ME_SEPARATELY_MINIMUM_32_BYTES
DATA_ENCRYPTION_KEY=CHANGE_ME_32_RANDOM_BYTES_BASE64URL
PROVIDER=taler-wallet-cli
TALER_WALLET_CLI=taler-wallet-cli
TALER_WALLET_DB=/data/taler-wallet.sqlite3
TALER_EXCHANGE_BASE_URL=https://exchange.example.invalid/
SUPPORTED_CURRENCIES=EUR
MAX_REWARD_VALUE=100
DAILY_PAYOUT_LIMITS=EUR:1000
LIQUIDITY_MIN_BALANCES=EUR:250
LIQUIDITY_MAX_AGE_SECONDS=300
LIQUIDITY_CHECK_INTERVAL_SECONDS=60
LIQUIDITY_FAIL_CLOSED=true
RETENTION_INTERVAL_SECONDS=86400
CLAIM_TOKEN_RETENTION_DAYS=30
PROVIDER_SECRET_RETENTION_DAYS=30
WEBHOOK_DELIVERED_RETENTION_DAYS=90
WEBHOOK_FAILED_RETENTION_DAYS=180
REVOKED_KEY_RETENTION_DAYS=365
TALER_ALLOW_HTTP=false
WEBHOOK_ALLOW_PRIVATE=false
METRICS_ENABLED=true
